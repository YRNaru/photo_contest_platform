# MySQL（docker-compose の db サービスと一致。ホストから接続する場合はポート 13306）
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=contest
MYSQL_USER=contestuser
MYSQL_PASSWORD=contestpass

# Django
DEBUG=True
SECRET_KEY=your-secret-key-here
DATABASE_URL=mysql://contestuser:contestpass@db:3306/contest
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:13000,http://127.0.0.1:13000
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# 本番(DEBUG=False)かつ HTTP のみのとき、Secure 属性付き CSRF/Session クッキーが保存されず管理画面で 403 になる。
# その暫定対策のみ False。HTTPS 運用では True または未設定のまま。
# SESSION_CSRF_COOKIE_SECURE=False

# Google OAuth（Google Cloud Consoleから取得）
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Twitter OAuth 2.0（Twitter Developer Portalから取得）
TWITTER_OAUTH_CLIENT_ID=your-twitter-client-id
TWITTER_OAUTH_CLIENT_SECRET=your-twitter-client-secret

# Twitter API v2（Twitter Developer Portalから取得）
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:18001/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_TWITTER_ENABLED=true
NODE_ENV=development
