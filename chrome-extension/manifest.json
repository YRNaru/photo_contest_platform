{
  "manifest_version": 3,
  "name": "Photo Contest X Entry",
  "version": "0.1.0",
  "description": "Register X posts to the photo contest platform.",
  "permissions": ["identity", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Photo Contest X Entry"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
