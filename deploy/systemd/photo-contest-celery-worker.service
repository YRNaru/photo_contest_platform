[Unit]
Description=Photo Contest Celery Worker
After=network.target mysql.service redis-server.service
Wants=mysql.service redis-server.service

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/srv/photo_contest/backend
EnvironmentFile=/etc/photo_contest.env
ExecStart=/srv/photo_contest/backend/venv/bin/celery \
    -A config worker -l info --concurrency=2
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
