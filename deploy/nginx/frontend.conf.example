# フロントエンド（Next.js）用 Nginx server ブロック
# /etc/nginx/sites-available/photo-contest-frontend にコピーし、
# /etc/nginx/sites-enabled/ にシンボリックリンクを張って利用する。
#
# ドメイン名は自分の環境に合わせて書き換えること。
# SSL は certbot --nginx で自動追加される想定。

upstream nextjs_frontend {
    server 127.0.0.1:3000;
}

server {
    listen 80;
    server_name www.example.com;

    client_max_body_size 10M;

    location / {
        proxy_pass http://nextjs_frontend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;

        # WebSocket 対応（Next.js HMR は本番では不要だが念のため）
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
